# ═══════════════════════════════════════════════════════
#  AUDITOR AI — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# Run: copy .env.example .env (Windows) or cp .env.example .env (Mac/Linux)

# ── Authentication ──
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256

# ── MongoDB ──
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=legal_document_summarizer

# ── Google Gemini AI (Free Tier) ──
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key

# ── Pinecone Vector Database ──
# Sign up: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=legal-docs
PINECONE_HOST=your-pinecone-host-url

# ── Redis / Upstash (Optional — app works without it) ──
# For Upstash: https://upstash.com/ (free tier available)
# Format: redis://default:password@host:port
# REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# ── File Uploads ──
UPLOADS_DIR=uploads
